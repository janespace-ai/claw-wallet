{
  "relayUrl": "https://relay.your-domain.com",
  "dataDir": "~/.claw-wallet",
  "defaultChain": "base",
  "chains": {
    "ethereum": {
      "rpcUrl": "https://ethereum.publicnode.com"
    },
    "base": {
      "rpcUrl": "https://mainnet.base.org"
    }
  },
  "pairTimeoutMs": 10000,
  "relayTimeoutMs": 30000,
  "signTimeoutMs": 120000,
  "policy": {
    "perTxLimitUsd": 100,
    "dailyLimitUsd": 500,
    "mode": "supervised"
  }
}
