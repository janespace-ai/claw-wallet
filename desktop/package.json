{
  "name": "claw-wallet-desktop",
  "version": "0.1.0",
  "description": "Claw Wallet Desktop - Electron-based secure wallet for OpenClaw Agent",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "rm -rf dist/main dist/shared && (tsc -p tsconfig.main.json --noEmitOnError false || true)",
    "dev": "npm run build && node scripts/run-electron.mjs",
    "build": "npm run build:main && tsc -p tsconfig.preload.json && npm run copy-assets",
    "typecheck": "tsc --noEmit",
    "copy-assets": "cp -r src/renderer dist/ && rm -rf dist/renderer/locales && cp -R locales dist/renderer/locales",
    "package": "electron-builder --config electron-builder.yml",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.0",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "ethers": "^6.16.0",
    "i18next": "^26.0.1",
    "i18next-resources-to-backend": "^1.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "electron": "41.0.3",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
