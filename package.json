{
  "name": "claw-wallet",
  "version": "0.1.0",
  "description": "Web3 wallet plugin for OpenClaw AI Agent framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "claw-signer": "./bin/claw-signer.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "wallet",
    "web3",
    "ethereum",
    "ai-agent",
    "evm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "viem": "^2.47.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
}
