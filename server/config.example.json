{
  "port": "8080",
  "corsAllowedOrigins": ["*"],
  "gracefulShutdown": "10s",
  "ws": {
    "readLimitBytes": 65536,
    "readTimeout": "60s",
    "writeTimeout": "10s",
    "pingInterval": "30s",
    "sendBufferSize": 64
  },
  "rateLimit": {
    "messageRate": 100,
    "connectionRate": 10,
    "maxIPsPerPair": 2,
    "maxClientsPerPair": 2,
    "maxConnectionsPerIP": 10,
    "cleanupInterval": "5m"
  },
  "pairing": {
    "codeLength": 8,
    "codeTTL": "10m",
    "ipRateLimit": 10,
    "cleanupInterval": "1m"
  }
}
